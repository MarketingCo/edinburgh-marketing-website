---
import Layout from '../layouts/Layout.astro';
import GlobalMap from '../components/GlobalMap.astro';
---

<Layout title="About Us | 15+ Years of Edinburgh Marketing Excellence" description="Learn about the history, mission, and expert team behind Edinburgh's most trusted marketing agency since 2011.">
	<!-- Mission Hero -->
	<section class="py-32 bg-slate-50 relative overflow-hidden">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
				<div>
					<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-6">Our Mission</h2>
					<h1 class="text-5xl lg:text-7xl font-extrabold text-[#0A192F] leading-tight mb-8">
						Rooted in <span class="text-[#6B4C9A]">Edinburgh.</span><br/>Driven by Data.
					</h1>
					<p class="text-xl text-gray-500 mb-10 leading-relaxed max-w-lg">
						Since our founding in 2011, we've had one single-minded goal: to help Edinburgh's local businesses dominate the digital landscape with precision and transparency.
					</p>
					<div class="flex items-center space-x-6">
						<div class="flex flex-col">
							<span class="text-5xl font-black text-[#0A192F]">2011</span>
							<span class="text-xs font-black text-[#6B4C9A] uppercase tracking-widest mt-2">Established</span>
						</div>
						<div class="w-px h-12 bg-gray-200"></div>
						<div class="flex flex-col">
							<span class="text-5xl font-black text-[#0A192F]">500+</span>
							<span class="text-xs font-black text-[#6B4C9A] uppercase tracking-widest mt-2">Clients Served</span>
						</div>
					</div>
				</div>
				<div class="relative bg-[#0A192F] p-12 rounded-[4rem] shadow-2xl border border-white/5 overflow-hidden group">
					<div class="absolute -top-10 -right-10 w-96 h-96 bg-[#6B4C9A] rounded-full filter blur-[120px] opacity-20 group-hover:opacity-30 transition-opacity"></div>
					<div class="relative z-10 text-white space-y-8">
						<div class="bg-white/5 p-8 rounded-3xl border border-white/10 backdrop-blur-sm">
							<h4 class="text-2xl font-black mb-4">The First 5 Years</h4>
							<p class="text-purple-100/80 leading-relaxed">Starting from a small office in Leith, we focused on the emerging world of local SEO and mobile-first design, long before they were industry standards.</p>
						</div>
						<div class="bg-white/5 p-8 rounded-3xl border border-white/10 backdrop-blur-sm">
							<h4 class="text-2xl font-black mb-4">Legacy of Growth</h4>
							<p class="text-purple-100/80 leading-relaxed">Today, we manage multi-million pound ad budgets for some of Scotland's most iconic local brands, while staying true to our local roots.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Global Impact Section -->
	<section class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<GlobalMap />
		</div>
	</section>

	<!-- Tech Stack Section -->
	<section class="py-32 bg-slate-50 border-y border-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-24">
				<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-4">Elite Infrastructure</h2>
				<p class="text-4xl lg:text-5xl font-extrabold text-[#0A192F]">The Tools of <span class="text-[#6B4C9A]">The Machine.</span></p>
			</div>

			<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
				<div class="p-8 bg-white rounded-3xl border border-gray-100 text-center shadow-sm">
					<div class="font-black text-[#0A192F] text-xl mb-2">HubSpot</div>
					<span class="text-[10px] font-black text-[#6B4C9A] uppercase tracking-widest">Enterprise CRM</span>
				</div>
				<div class="p-8 bg-white rounded-3xl border border-gray-100 text-center shadow-sm">
					<div class="font-black text-[#0A192F] text-xl mb-2">SEMrush</div>
					<span class="text-[10px] font-black text-[#6B4C9A] uppercase tracking-widest">Competitor Intel</span>
				</div>
				<div class="p-8 bg-white rounded-3xl border border-gray-100 text-center shadow-sm">
					<div class="font-black text-[#0A192F] text-xl mb-2">Claude Pro</div>
					<span class="text-[10px] font-black text-[#6B4C9A] uppercase tracking-widest">AI Copywriting</span>
				</div>
				<div class="p-8 bg-white rounded-3xl border border-gray-100 text-center shadow-sm">
					<div class="font-black text-[#0A192F] text-xl mb-2">Supermetrics</div>
					<span class="text-[10px] font-black text-[#6B4C9A] uppercase tracking-widest">Data Automation</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Compliance Section -->
	<section class="py-32 bg-[#0A192F] relative overflow-hidden">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
				<div>
					<h2 class="text-sm font-black text-purple-400 uppercase tracking-[0.4em] mb-6">Enterprise Ready</h2>
					<h3 class="text-4xl lg:text-6xl font-extrabold text-white leading-tight mb-8">
						Security-First <br/><span class="text-[#6B4C9A]">Operations.</span>
					</h3>
					<p class="text-xl text-purple-100/60 mb-10 leading-relaxed">
						We handle data for some of Edinburgh's most prestigious firms. Our systems are built to meet the highest standards of security and compliance, ensuring your business and client data is always protected.
					</p>
					<div class="grid grid-cols-2 gap-6">
						<div class="flex items-center space-x-3 text-white/80 font-bold">
							<svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"></path></svg>
							<span>GDPR Compliant</span>
						</div>
						<div class="flex items-center space-x-3 text-white/80 font-bold">
							<svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"></path></svg>
							<span>Encrypted Reporting</span>
						</div>
						<div class="flex items-center space-x-3 text-white/80 font-bold">
							<svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"></path></svg>
							<span>Ethical AI Standards</span>
						</div>
						<div class="flex items-center space-x-3 text-white/80 font-bold">
							<svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"></path></svg>
							<span>Secure Client Portals</span>
						</div>
					</div>
				</div>
				<div class="relative">
					<div class="w-full aspect-square bg-white/5 rounded-full border border-white/10 flex items-center justify-center relative">
						<div class="absolute inset-0 animate-ping opacity-10">
							<div class="w-full h-full border-2 border-white rounded-full"></div>
						</div>
						<svg class="w-32 h-32 text-[#6B4C9A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-7.618 3.04C5.459 9.131 5.821 11.512 7.062 13.523a9.981 9.981 0 001.295 1.545 11.93 11.93 0 012.308-1.442c.707-.348 1.487-.525 2.275-.525.787 0 1.567.177 2.275.525a11.921 11.921 0 012.308 1.442 9.98 9.98 0 001.295-1.545c1.241-2.011 1.603-4.392 2.256-7.539z"></path></svg>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Values Section -->
	<section class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-24">
				<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-4">Our Core Values</h2>
				<p class="text-4xl lg:text-5xl font-extrabold text-[#0A192F]">What Drives <span class="text-[#6B4C9A]">Our Culture?</span></p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
				<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-gray-100 hover:border-[#6B4C9A]/20 transition-all">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 rounded-2xl flex items-center justify-center mb-8 text-[#6B4C9A]">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold text-[#0A192F] mb-4 tracking-tighter">Speed of Execution</h3>
					<p class="text-gray-500 leading-relaxed italic">"In digital marketing, speed is everything. We move fast, but we never compromise on quality."</p>
				</div>
				<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-gray-100 hover:border-[#6B4C9A]/20 transition-all">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 rounded-2xl flex items-center justify-center mb-8 text-[#6B4C9A]">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-7.618 3.04C5.459 9.131 5.821 11.512 7.062 13.523a9.981 9.981 0 001.295 1.545 11.93 11.93 0 012.308-1.442c.707-.348 1.487-.525 2.275-.525.787 0 1.567.177 2.275.525a11.921 11.921 0 012.308 1.442 9.98 9.98 0 001.295-1.545c1.241-2.011 1.603-4.392 2.256-7.539z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold text-[#0A192F] mb-4 tracking-tighter">Radical Transparency</h3>
					<p class="text-gray-500 leading-relaxed italic">"No hidden fees, no opaque reporting. You see every penny spent and every result achieved."</p>
				</div>
				<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-gray-100 hover:border-[#6B4C9A]/20 transition-all">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 rounded-2xl flex items-center justify-center mb-8 text-[#6B4C9A]">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold text-[#0A192F] mb-4 tracking-tighter">Hyper-Local Expertise</h3>
					<p class="text-gray-500 leading-relaxed italic">"We know Edinburgh better than anyone. From the West End to Portobello, we understand the local nuances."</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Call to Action -->
	<section class="py-24 bg-[#0A192F] text-center">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
			<h3 class="text-4xl font-black text-white mb-8 leading-tight">Partner with Edinburgh's Finest.</h3>
			<p class="text-lg text-gray-400 mb-12">Let's build your success story together. Get started with your free digital audit today.</p>
			<a href="/#contact" class="bg-[#6B4C9A] text-white px-10 py-5 rounded-2xl font-black text-lg hover:bg-[#5A3B8A] transition-all inline-block shadow-lg">
				Start My Audit
			</a>
		</div>
	</section>
</Layout>
