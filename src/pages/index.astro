---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ROICalculator from '../components/ROICalculator';
import DashboardPreview from '../components/DashboardPreview.astro';
import SEOAuditTool from '../components/SEOAuditTool';
import TestimonialSlider from '../components/TestimonialSlider';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const caseStudies = (await getCollection('case-studies'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<Layout>
	<!-- Local Business Schema -->
	<script type="application/ld+json" slot="head">
	  {
		"@context": "https://schema.org",
		"@type": "MarketingAgency",
		"name": "Marketing Company Edinburgh",
		"image": "https://marketing-company.co.uk/og-image.jpg",
		"url": "https://marketing-company.co.uk",
		"telephone": "01315550000",
		"address": {
		  "@type": "PostalAddress",
		  "streetAddress": "123 Princes Street",
		  "addressLocality": "Edinburgh",
		  "postalCode": "EH2 4AD",
		  "addressCountry": "GB"
		},
		"geo": {
		  "@type": "GeoCoordinates",
		  "latitude": 55.9520,
		  "longitude": -3.1965
		},
		"openingHoursSpecification": {
		  "@type": "OpeningHoursSpecification",
		  "dayOfWeek": [
			"Monday",
			"Tuesday",
			"Wednesday",
			"Thursday",
			"Friday"
		  ],
		  "opens": "09:00",
		  "closes": "17:30"
		},
		"sameAs": [
		  "https://www.linkedin.com/company/marketing-company-edinburgh",
		  "https://twitter.com/marketingco_ed"
		]
	  }
	</script>

	<script type="application/ld+json" slot="head">
	  {
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": [
		  {
			"@type": "Question",
			"name": "How long does SEO take in Edinburgh?",
			"acceptedAnswer": {
			  "@type": "Answer",
			  "text": "While initial technical improvements can show results in weeks, a comprehensive local SEO strategy in the competitive Edinburgh market typically takes 3-6 months to see significant movement in rankings and traffic."
			}
		  },
		  {
			"@type": "Question",
			"name": "Do you only work with Edinburgh businesses?",
			"acceptedAnswer": {
			  "@type": "Answer",
			  "text": "While we are proudly based in Edinburgh and specialize in the local market, we also work with national Scottish brands and businesses across the UK who value our data-driven approach."
			}
		  },
		  {
			"@type": "Question",
			"name": "What is included in a Free Strategy Audit?",
			"acceptedAnswer": {
			  "@type": "Answer",
			  "text": "Our audit includes a review of your current technical SEO, a breakdown of your local Edinburgh competitors, an analysis of your PPC opportunities, and a high-level roadmap for growth."
			}
		  }
		]
	  }
	</script>

	<!-- Hero Section -->
	<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-slate-50 pt-10">
		<div class="absolute inset-0 z-0">
			<div class="absolute top-0 -left-4 w-72 h-72 bg-[#6B4C9A] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
			<div class="absolute top-0 -right-4 w-72 h-72 bg-[#0A192F] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>
			<div class="absolute -bottom-8 left-20 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-4000"></div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-purple-100 text-[#6B4C9A] text-xs font-bold uppercase tracking-wider mb-8">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-[#6B4C9A]"></span>
						</span>
						<span>Multi-Sector Market Domination</span>
					</div>
					<h1 class="text-5xl lg:text-7xl font-extrabold text-[#0A192F] leading-[1.1] tracking-tight mb-8">
						Market Domination for the <span class="text-[#6B4C9A]">Construction Sector</span>
					</h1>
					<p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-lg">
						We combine Edinburgh expertise with data-driven engineering to help high-performance businesses dominate the Scottish market.
					</p>
					<div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-6">
						<a href="#contact" class="bg-[#6B4C9A] text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-[#5A3B8A] transition-all shadow-lg hover:shadow-purple-200 text-center">
							Initiate Consultation
						</a>
						<a href="#services" class="border-2 border-[#0A192F] text-[#0A192F] px-8 py-4 rounded-full text-lg font-bold hover:bg-[#0A192F] hover:text-white transition-all text-center">
							View Services
						</a>
					</div>
					<div class="mt-12 flex items-center space-x-6">
						<div class="flex -space-x-3">
							<div class="w-10 h-10 rounded-full bg-gray-200 border-2 border-white flex items-center justify-center text-[10px] font-bold">5.0</div>
							<div class="w-10 h-10 rounded-full bg-gray-300 border-2 border-white"></div>
							<div class="w-10 h-10 rounded-full bg-gray-400 border-2 border-white"></div>
						</div>
						<p class="text-sm text-gray-500 font-medium">Trusted by 50+ Edinburgh local businesses</p>
					</div>
				</div>
				<div id="roi" class="hidden lg:block relative">
					<ROICalculator client:visible />
					<!-- Abstract background graphic -->
					<div class="absolute -bottom-10 -right-10 w-full h-full border-2 border-[#6B4C9A]/20 rounded-3xl -z-10 translate-x-4 translate-y-4"></div>
				</div>
			</div>
		</div>

		<!-- Client Trust Bar -->
		<div class="absolute bottom-0 w-full bg-white/50 backdrop-blur-sm border-t border-gray-100 py-6 overflow-hidden hidden md:block">
			<div class="max-w-7xl mx-auto px-4 flex items-center justify-between opacity-40 grayscale hover:grayscale-0 transition-all duration-700">
				<span class="text-xs font-black uppercase tracking-[0.3em] text-[#0A192F]">Established Partner:</span>
				<div class="flex space-x-12 animate-scroll">
					<span class="text-lg font-black tracking-tighter">EDINBURGH EATS</span>
					<span class="text-lg font-black tracking-tighter">LEITH LOGISTICS</span>
					<span class="text-lg font-black tracking-tighter">ST. ANDREW'S RETAIL</span>
					<span class="text-lg font-black tracking-tighter">HIGHLAND HOMES</span>
					<span class="text-lg font-black tracking-tighter">PRINCES ST. LEGAL</span>
					<span class="text-lg font-black tracking-tighter">SCOTTISH TECH HUB</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Brand Showcase Section -->
	<section class="py-20 bg-slate-50 border-b border-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col lg:flex-row items-center justify-between gap-12">
				<div class="max-w-xs text-center lg:text-left">
					<h4 class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.3em] mb-2">Social Proof</h4>
					<p class="text-sm font-bold text-[#0A192F] opacity-60 uppercase tracking-widest">Powering growth for Edinburgh's most iconic local brands since 2011.</p>
				</div>
				<div class="flex-1 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 opacity-30 grayscale hover:grayscale-0 transition-all duration-700">
					<div class="flex items-center justify-center font-black text-xl tracking-tighter">CASTLE RETAIL</div>
					<div class="flex items-center justify-center font-black text-xl tracking-tighter">LOTHIAN TECH</div>
					<div class="flex items-center justify-center font-black text-xl tracking-tighter">WAVERLEY LAW</div>
					<div class="flex items-center justify-center font-black text-xl tracking-tighter">HOLYROOD HOMES</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section id="services" class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-24">
				<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-4">Our Services</h2>
				<p class="text-4xl lg:text-5xl font-extrabold text-[#0A192F] mb-6">Built for Edinburgh Growth.</p>
				<p class="text-xl text-gray-500 max-w-2xl mx-auto">Specific digital marketing solutions designed to help local businesses thrive in the competitive Edinburgh market.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- SEO Card -->
				<div class="group p-10 rounded-[2.5rem] bg-slate-50 hover:bg-[#0A192F] transition-all duration-500 border border-gray-100">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 group-hover:bg-white/10 rounded-2xl flex items-center justify-center mb-8 transition-colors">
						<svg class="w-8 h-8 text-[#6B4C9A] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold mb-4 text-[#0A192F] group-hover:text-white transition-colors">Local SEO</h3>
					<p class="text-gray-500 group-hover:text-gray-400 mb-8 leading-relaxed transition-colors">
						Rank #1 in Edinburgh search results. We optimize your Google Business Profile and local keywords to drive local foot traffic.
					</p>
					<a href="/services/local-seo" class="inline-flex items-center text-sm font-black text-[#6B4C9A] group-hover:text-white uppercase tracking-widest mb-10">
						Explore Strategy
						<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
					</a>
				</div>

				<!-- PPC Card -->
				<div class="group p-10 rounded-[2.5rem] bg-white hover:bg-[#6B4C9A] transition-all duration-500 shadow-xl shadow-gray-100 border border-gray-50">
					<div class="w-16 h-16 bg-[#0A192F]/10 group-hover:bg-white/10 rounded-2xl flex items-center justify-center mb-8 transition-colors">
						<svg class="w-8 h-8 text-[#0A192F] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
					</div>
					<h3 class="text-2xl font-bold mb-4 text-[#0A192F] group-hover:text-white transition-colors">Paid Advertising</h3>
					<p class="text-gray-500 group-hover:text-white/80 mb-8 leading-relaxed transition-colors">
						Instant leads through Google and Meta ads. We target the specific Edinburgh postcodes that matter most to your bottom line.
					</p>
					<a href="/services/paid-advertising" class="inline-flex items-center text-sm font-black text-[#0A192F] group-hover:text-white uppercase tracking-widest mb-10">
						Explore Strategy
						<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
					</a>
				</div>

				<!-- Web Design -->
				<div class="group p-10 rounded-[2.5rem] bg-slate-50 hover:bg-[#0A192F] transition-all duration-500 border border-gray-100">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 group-hover:bg-white/10 rounded-2xl flex items-center justify-center mb-8 transition-colors">
						<svg class="w-8 h-8 text-[#6B4C9A] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold mb-4 text-[#0A192F] group-hover:text-white transition-colors">Web Design</h3>
					<p class="text-gray-500 group-hover:text-gray-400 mb-8 leading-relaxed transition-colors">
						High-performance websites that convert Edinburgh visitors into customers. Fast, mobile-first, and SEO-ready.
					</p>
					<a href="/services/web-design" class="inline-flex items-center text-sm font-black text-[#6B4C9A] group-hover:text-white uppercase tracking-widest mb-10">
						Explore Strategy
						<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
					</a>
				</div>

				<!-- Social Media Card -->
				<div class="group p-10 rounded-[2.5rem] bg-white hover:bg-[#6B4C9A] transition-all duration-500 shadow-xl shadow-gray-100 border border-gray-50">
					<div class="w-16 h-16 bg-[#0A192F]/10 group-hover:bg-white/10 rounded-2xl flex items-center justify-center mb-8 transition-colors">
						<svg class="w-8 h-8 text-[#0A192F] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold mb-4 text-[#0A192F] group-hover:text-white transition-colors">Social Management</h3>
					<p class="text-gray-500 group-hover:text-white/80 mb-8 leading-relaxed transition-colors">
						Build a loyal community in Edinburgh. We handle everything from content creation to community engagement.
					</p>
					<ul class="space-y-3 mb-10 text-sm font-semibold text-[#0A192F] group-hover:text-white transition-colors">
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#0A192F] group-hover:bg-white rounded-full mr-3"></span>Content Calendar</li>
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#0A192F] group-hover:bg-white rounded-full mr-3"></span>Influencer Outreach</li>
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#0A192F] group-hover:bg-white rounded-full mr-3"></span>Analytics Reporting</li>
					</ul>
				</div>

				<!-- Content Marketing Card -->
				<div class="group p-10 rounded-[2.5rem] bg-slate-50 hover:bg-[#0A192F] transition-all duration-500 border border-gray-100">
					<div class="w-16 h-16 bg-[#6B4C9A]/10 group-hover:bg-white/10 rounded-2xl flex items-center justify-center mb-8 transition-colors">
						<svg class="w-8 h-8 text-[#6B4C9A] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold mb-4 text-[#0A192F] group-hover:text-white transition-colors">Content Strategy</h3>
					<p class="text-gray-500 group-hover:text-gray-400 mb-8 leading-relaxed transition-colors">
						Position your business as an Edinburgh authority. We produce blogs, guides, and whitepapers that drive trust.
					</p>
					<ul class="space-y-3 mb-10 text-sm font-semibold text-[#0A192F] group-hover:text-white transition-colors">
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#6B4C9A] group-hover:bg-white rounded-full mr-3"></span>SEO Copywriting</li>
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#6B4C9A] group-hover:bg-white rounded-full mr-3"></span>Email Marketing</li>
						<li class="flex items-center"><span class="w-1.5 h-1.5 bg-[#6B4C9A] group-hover:bg-white rounded-full mr-3"></span>Video Scripts</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Edinburgh Section -->
	<section id="about" class="py-32 bg-[#0A192F] relative overflow-hidden">
		<div class="absolute inset-0 opacity-10">
			<div class="grid grid-cols-12 h-full">
				{Array.from({ length: 12 }).map(() => (
					<div class="border-r border-white/20 h-full"></div>
				))}
			</div>
		</div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
				<div>
					<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-6">Local Advantage</h2>
					<h3 class="text-4xl lg:text-6xl font-extrabold text-white leading-tight mb-8">
						Why a Local Edinburgh Agency <span class="text-[#6B4C9A]">Wins.</span>
					</h3>
					<div class="space-y-8">
						<div class="flex items-start">
							<div class="w-12 h-12 bg-[#6B4C9A] rounded-xl flex items-center justify-center mr-6 flex-shrink-0 text-white font-bold">01</div>
							<div>
								<h4 class="text-xl font-bold text-white mb-2">Market Understanding</h4>
								<p class="text-gray-400 leading-relaxed">We understand the unique demographics and consumer behavior across Edinburgh, from Stockbridge to Leith.</p>
							</div>
						</div>
						<div class="flex items-start">
							<div class="w-12 h-12 bg-[#6B4C9A] rounded-xl flex items-center justify-center mr-6 flex-shrink-0 text-white font-bold">02</div>
							<div>
								<h4 class="text-xl font-bold text-white mb-2">Local Networking</h4>
								<p class="text-gray-400 leading-relaxed">Leverage our connections with local Scottish media, influencers, and business networks to amplify your brand.</p>
							</div>
						</div>
						<div class="flex items-start">
							<div class="w-12 h-12 bg-[#6B4C9A] rounded-xl flex items-center justify-center mr-6 flex-shrink-0 text-white font-bold">03</div>
							<div>
								<h4 class="text-xl font-bold text-white mb-2">Face-to-Face Strategy</h4>
								<p class="text-gray-400 leading-relaxed">No more anonymous Zoom calls. We're happy to meet for coffee on George Street to discuss your growth.</p>
							</div>
						</div>
					</div>
				</div>
				<div class="bg-gradient-to-br from-[#1A2E4C] to-[#0A192F] p-12 rounded-[3rem] border border-white/5 relative">
					<div class="absolute -top-10 -right-10 w-40 h-40 bg-[#6B4C9A] rounded-full filter blur-[100px] opacity-30"></div>
					<div class="grid grid-cols-2 gap-8 text-center">
						<div>
							<span class="text-5xl font-black text-white block mb-2">15+</span>
							<span class="text-[#6B4C9A] font-bold text-sm uppercase">Years in Edinburgh</span>
						</div>
						<div>
							<span class="text-5xl font-black text-white block mb-2">85%</span>
							<span class="text-[#6B4C9A] font-bold text-sm uppercase">Retention Rate</span>
						</div>
						<div>
							<span class="text-5xl font-black text-white block mb-2">£2M+</span>
							<span class="text-[#6B4C9A] font-bold text-sm uppercase">Client Ad Spend</span>
						</div>
						<div>
							<span class="text-5xl font-black text-white block mb-2">500k</span>
							<span class="text-[#6B4C9A] font-bold text-sm uppercase">Leads Generated</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- The £20k Domination Engine Section -->
	<section class="py-32 bg-white relative overflow-hidden">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="bg-gradient-to-br from-[#0A192F] to-[#1A2E4C] rounded-[4rem] p-12 lg:p-24 overflow-hidden relative shadow-2xl">
				<div class="absolute top-0 right-0 w-96 h-96 bg-[#6B4C9A] rounded-full filter blur-[150px] opacity-20 -mr-48 -mt-48"></div>
				
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
					<div>
						<div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-[#6B4C9A]/20 text-[#6B4C9A] text-xs font-bold uppercase tracking-wider mb-8">
							<span>Network Strategy as a Service</span>
						</div>
						<h2 class="text-4xl lg:text-6xl font-black text-white mb-8 leading-tight">
							The £20k <br/><span class="text-[#6B4C9A]">Domination Engine.</span>
						</h2>
						<p class="text-xl text-purple-100/60 mb-12 max-w-md">
							Our proprietary network strategy isn't just marketing; it's a market-conquering ecosystem designed to build an 'Ecosystem of Trust' across the Scottish capital.
						</p>
						<ul class="space-y-6 mb-12">
							<li class="flex items-center text-white font-bold">
								<svg class="w-6 h-6 text-[#6B4C9A] mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								10x Local Neighborhood Landing Pages
							</li>
							<li class="flex items-center text-white font-bold">
								<svg class="w-6 h-6 text-[#6B4C9A] mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								Dynamic LocalBusiness Schema Injection
