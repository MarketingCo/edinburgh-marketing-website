---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const guides = (await getCollection('guides')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Knowledge Hub | Edinburgh Marketing Resources" description="Your library for Edinburgh marketing insights, high-value growth guides, and expert digital strategies.">
	<section class="py-32 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-24">
				<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-4">The Library</h2>
				<h1 class="text-5xl lg:text-7xl font-extrabold text-[#0A192F] mb-6">Knowledge Hub <span class="text-[#6B4C9A]">for Edinburgh.</span></h1>
				<p class="text-xl text-gray-500 max-w-2xl mx-auto">Expert guides, industry analysis, and the latest marketing trends for the Scottish capital.</p>
			</div>

			<!-- Featured Guides Section -->
			<div class="mb-32">
				<div class="flex justify-between items-end mb-12">
					<h2 class="text-3xl font-black text-[#0A192F]">Growth Guides</h2>
					<span class="text-xs font-black text-gray-400 uppercase tracking-widest">{guides.length} Resources Available</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
					{guides.map((guide) => (
						<div class="bg-[#0A192F] rounded-[3.5rem] p-12 lg:p-16 text-white shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-transform">
							<div class="absolute -top-10 -right-10 w-40 h-40 bg-[#6B4C9A] rounded-full filter blur-[100px] opacity-20 group-hover:opacity-40 transition-opacity"></div>
							<div class="relative z-10">
								<span class="px-4 py-1.5 bg-white/10 text-purple-200 text-xs font-black uppercase tracking-widest rounded-full mb-8 inline-block">{guide.data.category}</span>
								<h3 class="text-4xl font-black mb-6 leading-tight">{guide.data.title}</h3>
								<p class="text-purple-100/60 text-xl mb-10 leading-relaxed italic">"{guide.data.description}"</p>
								<a href={`/contact`} class="bg-[#6B4C9A] text-white px-8 py-4 rounded-2xl font-black text-sm hover:bg-[#5A3B8A] transition-all inline-block shadow-lg">
									Request Free Copy
								</a>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Digital Products Section -->
			<div class="mb-32">
				<div class="flex justify-between items-end mb-12">
					<h2 class="text-3xl font-black text-[#0A192F]">Instant Strategy Packs</h2>
					<span class="text-xs font-black text-gray-400 uppercase tracking-widest">Immediate Download</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="p-10 rounded-[2.5rem] bg-white border border-gray-100 shadow-xl shadow-gray-100/50 group">
						<div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6 text-[#6B4C9A]">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<h4 class="text-xl font-black text-[#0A192F] mb-4">Local SEO Checklist</h4>
						<p class="text-gray-500 text-sm mb-8 leading-relaxed">Our internal 150-point checklist for dominating Edinburgh's local search results.</p>
						<div class="flex items-center justify-between">
							<span class="text-2xl font-black text-[#0A192F]">£49</span>
							<a href="/contact" class="text-sm font-black text-[#6B4C9A] uppercase tracking-widest hover:underline">Add to Cart</a>
						</div>
					</div>
					<div class="p-10 rounded-[2.5rem] bg-white border border-gray-100 shadow-xl shadow-gray-100/50 group">
						<div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6 text-[#6B4C9A]">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
						</div>
						<h4 class="text-xl font-black text-[#0A192F] mb-4">Video Strategy Pack</h4>
						<p class="text-gray-500 text-sm mb-8 leading-relaxed">Templates and scripts for high-converting social video ads in the Scottish market.</p>
						<div class="flex items-center justify-between">
							<span class="text-2xl font-black text-[#0A192F]">£99</span>
							<a href="/contact" class="text-sm font-black text-[#6B4C9A] uppercase tracking-widest hover:underline">Add to Cart</a>
						</div>
					</div>
					<div class="p-10 rounded-[2.5rem] bg-white border border-gray-100 shadow-xl shadow-gray-100/50 group">
						<div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6 text-[#6B4C9A]">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
						</div>
						<h4 class="text-xl font-black text-[#0A192F] mb-4">Content Calendar</h4>
						<p class="text-gray-500 text-sm mb-8 leading-relaxed">A full year of Edinburgh-specific content ideas, events, and trending hashtags.</p>
						<div class="flex items-center justify-between">
							<span class="text-2xl font-black text-[#0A192F]">£29</span>
							<a href="/contact" class="text-sm font-black text-[#6B4C9A] uppercase tracking-widest hover:underline">Add to Cart</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Latest Blog Section -->
			<div>
				<div class="flex justify-between items-end mb-12">
					<h2 class="text-3xl font-black text-[#0A192F]">Latest Insights</h2>
					<a href="/blog" class="text-[#6B4C9A] font-bold inline-flex items-center hover:underline">
						View Blog
						<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
					</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{blogPosts.map((post) => (
						<article class="bg-white p-10 rounded-[2.5rem] shadow-xl shadow-gray-100 border border-gray-50 group hover:shadow-2xl transition-all">
							<div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">
								{post.data.pubDate.toLocaleDateString('en-gb', { month: 'short', year: 'numeric' })}
							</div>
							<h3 class="text-2xl font-black text-[#0A192F] mb-6 group-hover:text-[#6B4C9A] transition-colors leading-tight">
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</h3>
							<p class="text-gray-500 leading-relaxed mb-8 line-clamp-3">{post.data.description}</p>
							<a href={`/blog/${post.id}/`} class="text-[#0A192F] font-bold text-sm inline-flex items-center group-hover:underline">
								Read Analysis
								<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
							</a>
						</article>
					))}
				</div>
			</div>
		</div>
	</section>
</Layout>
