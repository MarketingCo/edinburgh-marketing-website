---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Edinburgh's Trusted Marketing Partners" description="Ready to grow your Edinburgh business? Get in touch with our expert team for a free digital audit and local strategy session.">
	<section class="py-32 bg-slate-50 relative overflow-hidden">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
				<div>
					<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-6">Get In Touch</h2>
					<h1 class="text-5xl lg:text-7xl font-extrabold text-[#0A192F] leading-tight mb-8">
						Let's Build Your <span class="text-[#6B4C9A]">Success Story.</span>
					</h1>
					<p class="text-xl text-gray-500 mb-12 leading-relaxed">
						Whether you're looking for a complete digital overhaul or targeted local SEO, our Edinburgh-based team is ready to help you dominate your market.
					</p>
					
					<div class="space-y-10">
						<div class="flex items-start">
							<div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center mr-6 text-[#6B4C9A] flex-shrink-0">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
							</div>
							<div>
								<h4 class="text-lg font-bold text-[#0A192F] mb-1 tracking-tight">Visit Our Office</h4>
								<p class="text-gray-500 leading-relaxed font-medium">123 Princes Street, Edinburgh, EH2 4AD</p>
							</div>
						</div>
						<div class="flex items-start">
							<div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center mr-6 text-[#6B4C9A] flex-shrink-0">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
							</div>
							<div>
								<h4 class="text-lg font-bold text-[#0A192F] mb-1 tracking-tight">Email Us</h4>
								<p class="text-gray-500 leading-relaxed font-medium">strategy@marketing-company.co.uk</p>
							</div>
						</div>
						<div class="flex items-start">
							<div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center mr-6 text-[#6B4C9A] flex-shrink-0">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
							</div>
							<div>
								<h4 class="text-lg font-bold text-[#0A192F] mb-1 tracking-tight">Call Us</h4>
								<p class="text-gray-500 leading-relaxed font-medium">0131 555 0000</p>
							</div>
						</div>
					</div>
				</div>
				
				<div class="bg-white p-10 lg:p-16 rounded-[3rem] shadow-2xl border border-gray-100 relative group">
					<div class="absolute -top-10 -right-10 w-40 h-40 bg-[#6B4C9A] rounded-full filter blur-[100px] opacity-10"></div>
					<form class="space-y-8 relative z-10">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
							<div class="space-y-2">
								<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Your Name</label>
								<input type="text" required placeholder="John Smith" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F]" />
							</div>
							<div class="space-y-2">
								<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Work Email</label>
								<input type="email" required placeholder="john@company.com" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F]" />
							</div>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
							<div class="space-y-2">
								<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Annual Revenue</label>
								<select required class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F]">
									<option value="">Select Range</option>
									<option value="under-250k">Under £250k</option>
									<option value="250k-1m">£250k - £1M</option>
									<option value="1m-5m">£1M - £5M</option>
									<option value="over-5m">£5M+</option>
								</select>
							</div>
							<div class="space-y-2">
								<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Monthly Budget</label>
								<select required class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F]">
									<option value="">Select Budget</option>
									<option value="under-1k">Under £1,000</option>
									<option value="1k-3k">£1,000 - £3,000</option>
									<option value="3k-10k">£3,000 - £10,000</option>
									<option value="over-10k">£10,000+</option>
								</select>
							</div>
						</div>
						<div class="space-y-2">
							<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Your Website</label>
							<input type="url" required placeholder="www.yourcompany.co.uk" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F]" />
						</div>
						<div class="space-y-2">
							<label class="text-xs font-black text-[#6B4C9A] uppercase tracking-[0.2em]">Current Growth Challenge</label>
							<textarea rows="4" placeholder="Briefly describe what is holding your Edinburgh business back..." class="w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:border-[#6B4C9A] focus:bg-white focus:ring-0 transition-all font-bold text-[#0A192F] resize-none"></textarea>
						</div>
						<button type="submit" class="w-full bg-[#0A192F] text-white py-6 rounded-2xl font-black text-xl hover:bg-[#1A2E4C] transition-all transform hover:scale-[1.02] shadow-xl shadow-[#0A192F]/20">
							Submit Application
						</button>
					</form>
				</div>
			</div>
		</div>
	</section>

	<!-- Map Section (Placeholder) -->
	<section class="h-[500px] bg-slate-200 relative overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000">
		<div class="absolute inset-0 flex items-center justify-center bg-[#0A192F]/5">
			<div class="text-center">
				<div class="w-20 h-20 bg-[#6B4C9A] rounded-full flex items-center justify-center mx-auto mb-6 shadow-xl animate-bounce">
					<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
				</div>
				<span class="text-sm font-black text-[#0A192F] uppercase tracking-[0.3em]">Visit us in the heart of Edinburgh</span>
			</div>
		</div>
		<!-- Mock Map Pattern -->
		<svg class="absolute inset-0 w-full h-full opacity-10" viewBox="0 0 100 100" preserveAspectRatio="none">
			<path d="M0,20 L100,80 M20,0 L80,100 M0,50 L100,50 M50,0 L50,100" stroke="#0A192F" stroke-width="0.1"></path>
		</svg>
	</section>
</Layout>
