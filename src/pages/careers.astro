---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Careers | Join Edinburgh's Leading Marketing Team" description="Grow your career with a team of marketing experts in the heart of Edinburgh. View our open roles and join us.">
	<section class="py-32 bg-slate-50 relative overflow-hidden text-center">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<h2 class="text-sm font-black text-[#6B4C9A] uppercase tracking-[0.2em] mb-6">Join the Team</h2>
			<h1 class="text-5xl lg:text-7xl font-extrabold text-[#0A192F] leading-[1.1] mb-8">
				Build the Future of <br/><span class="text-[#6B4C9A]">Edinburgh Marketing.</span>
			</h1>
			<p class="text-xl text-gray-500 mb-12 leading-relaxed max-w-2xl mx-auto">
				We're always looking for talented, ambitious digital marketers to join our team in the New Town. If you're passionate about results and local growth, we want to hear from you.
			</p>
			<a href="#roles" class="bg-[#0A192F] text-white px-10 py-5 rounded-2xl font-black text-lg hover:bg-[#1A2E4C] transition-all inline-block shadow-lg">
				View Open Roles
			</a>
		</div>
	</section>

	<section class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<div class="bg-slate-50 p-10 rounded-[2.5rem] border border-gray-100">
					<h3 class="text-2xl font-black text-[#0A192F] mb-4">Hybrid Working</h3>
					<p class="text-gray-500 leading-relaxed">Balance focus with collaboration. We offer a flexible hybrid model between our Princes St office and your home.</p>
				</div>
				<div class="bg-slate-50 p-10 rounded-[2.5rem] border border-gray-100">
					<h3 class="text-2xl font-black text-[#0A192F] mb-4">Growth Fund</h3>
					<p class="text-gray-500 leading-relaxed">Annual personal development budget for courses, conferences, and certifications.</p>
				</div>
				<div class="bg-slate-50 p-10 rounded-[2.5rem] border border-gray-100">
					<h3 class="text-2xl font-black text-[#0A192F] mb-4">Culture First</h3>
					<p class="text-gray-500 leading-relaxed">Regular team socials, local coffee perks, and a supportive, high-performance environment.</p>
				</div>
			</div>
		</div>
	</section>

	<section id="roles" class="py-32 bg-slate-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl lg:text-5xl font-black text-[#0A192F] mb-12">Open Opportunities</h2>
			<div class="space-y-6">
				<div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col md:flex-row justify-between items-center group">
					<div class="text-left mb-6 md:mb-0">
						<h4 class="text-xl font-black text-[#0A192F] group-hover:text-[#6B4C9A] transition-colors">Senior SEO Specialist</h4>
						<p class="text-gray-400 text-sm font-bold uppercase tracking-widest mt-1">Full-Time / Edinburgh Hybrid</p>
					</div>
					<a href="/contact" class="bg-slate-50 text-[#0A192F] px-8 py-3 rounded-xl font-bold hover:bg-[#6B4C9A] hover:text-white transition-all">Apply Now</a>
				</div>
				<div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col md:flex-row justify-between items-center group">
					<div class="text-left mb-6 md:mb-0">
						<h4 class="text-xl font-black text-[#0A192F] group-hover:text-[#6B4C9A] transition-colors">Digital Account Manager</h4>
						<p class="text-gray-400 text-sm font-bold uppercase tracking-widest mt-1">Full-Time / Edinburgh Hybrid</p>
					</div>
					<a href="/contact" class="bg-slate-50 text-[#0A192F] px-8 py-3 rounded-xl font-bold hover:bg-[#6B4C9A] hover:text-white transition-all">Apply Now</a>
				</div>
			</div>
			<p class="mt-16 text-gray-400 font-bold italic">Don't see a role? Send your CV anyway to careers@marketing-company.co.uk</p>
		</div>
	</section>
</Layout>
