---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Marketing Company Edinburgh" description="The page you are looking for does not exist. Let us help you get back on track to scaling your Edinburgh business.">
	<section class="min-h-[70vh] flex items-center justify-center bg-slate-50 relative overflow-hidden">
		<div class="absolute inset-0 z-0">
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#6B4C9A] rounded-full mix-blend-multiply filter blur-[120px] opacity-5 animate-pulse"></div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
			<span class="text-[12rem] font-black text-[#0A192F]/5 leading-none block mb-8">404</span>
			<h1 class="text-5xl lg:text-7xl font-black text-[#0A192F] mb-8 leading-tight">
				Lost in the <span class="text-[#6B4C9A]">Fog?</span>
			</h1>
			<p class="text-xl text-gray-500 mb-12 leading-relaxed max-w-lg mx-auto">
				It looks like the page you're looking for has disappeared into the Edinburgh mist. Let's get your growth strategy back on track.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6">
				<a href="/" class="bg-[#0A192F] text-white px-10 py-5 rounded-2xl font-black text-lg hover:bg-[#1A2E4C] transition-all shadow-xl">
					Back to Home
				</a>
				<a href="/contact" class="bg-[#6B4C9A] text-white px-10 py-5 rounded-2xl font-black text-lg hover:bg-[#5A3B8A] transition-all shadow-xl">
					Request Private Briefing
				</a>
			</div>
		</div>
	</section>
</Layout>
