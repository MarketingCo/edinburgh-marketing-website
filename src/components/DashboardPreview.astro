---
---
<div class="relative bg-[#0A192F] rounded-[4rem] p-8 lg:p-16 overflow-hidden border border-white/10 shadow-2xl group">
    <!-- Background glow -->
    <div class="absolute -top-20 -right-20 w-96 h-96 bg-[#6B4C9A] rounded-full filter blur-[120px] opacity-20 group-hover:opacity-30 transition-opacity"></div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
        <div>
            <span class="text-xs font-black text-purple-400 uppercase tracking-[0.4em] mb-6 block">Proprietary Infrastructure</span>
            <h3 class="text-3xl lg:text-5xl font-black text-white mb-8 leading-tight">Total Transparency. <br/><span class="text-[#6B4C9A]">Real-Time Data.</span></h3>
            <p class="text-lg text-purple-100/60 mb-10 leading-relaxed">
                Every Enterprise partner gets exclusive access to our **Marketing Intelligence Dashboard**. No more waiting for monthly PDF reports—see your ROI, lead flow, and market share in real-time.
            </p>
            <ul class="space-y-6">
                <li class="flex items-center space-x-4">
                    <div class="w-6 h-6 bg-purple-500/20 rounded-full flex items-center justify-center border border-purple-500/30">
                        <svg class="w-3 h-3 text-purple-400" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>
                    </div>
                    <span class="text-white font-bold">Multi-Channel Attribution Tracking</span>
                </li>
                <li class="flex items-center space-x-4">
                    <div class="w-6 h-6 bg-purple-500/20 rounded-full flex items-center justify-center border border-purple-500/30">
                        <svg class="w-3 h-3 text-purple-400" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>
                    </div>
                    <span class="text-white font-bold">Competitor Intelligence Monitoring</span>
                </li>
                <li class="flex items-center space-x-4">
                    <div class="w-6 h-6 bg-purple-500/20 rounded-full flex items-center justify-center border border-purple-500/30">
                        <svg class="w-3 h-3 text-purple-400" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>
                    </div>
                    <span class="text-white font-bold">Live ROI & Revenue Dashboards</span>
                </li>
            </ul>
        </div>

        <!-- Mockup Dashboard -->
        <div class="bg-white/5 backdrop-blur-xl rounded-3xl border border-white/10 p-6 shadow-3xl transform rotate-2 group-hover:rotate-0 transition-transform duration-700">
            <div class="flex items-center justify-between mb-8">
                <div class="flex space-x-2">
                    <div class="w-3 h-3 bg-red-500/50 rounded-full"></div>
                    <div class="w-3 h-3 bg-yellow-500/50 rounded-full"></div>
                    <div class="w-3 h-3 bg-green-500/50 rounded-full"></div>
                </div>
                <div class="text-[10px] font-black text-purple-400 uppercase tracking-widest">LIVE DATA FEED</div>
            </div>
            
            <div class="space-y-6">
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                        <span class="text-[10px] text-gray-400 font-bold uppercase block mb-1">Weekly Leads</span>
                        <span class="text-2xl font-black text-white">+142</span>
                    </div>
                    <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                        <span class="text-[10px] text-gray-400 font-bold uppercase block mb-1">Conversion</span>
                        <span class="text-2xl font-black text-[#6B4C9A]">4.8%</span>
                    </div>
                </div>
                
                <div class="bg-white/5 p-6 rounded-2xl border border-white/5 h-32 relative overflow-hidden">
                    <span class="text-[10px] text-gray-400 font-bold uppercase block mb-4">Revenue Attribution</span>
                    <!-- Simple SVG Graph -->
                    <svg class="w-full h-full text-purple-500" viewBox="0 0 100 40" preserveAspectRatio="none">
                        <path d="M0,40 L10,35 L20,38 L30,25 L40,28 L50,15 L60,18 L70,5 L80,10 L90,2 L100,8" fill="none" stroke="currentColor" stroke-width="2"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>
